{
  "form": {
    "title": "nf-core/cellconsensus pipeline parameters",
    "description": "Hierarchical unsupervised cell type annotation from consensus markers",
    "type": "object",
    "properties": {
      "annotate_options": {
        "title": "Annotation options",
        "type": "object",
        "fa_icon": "fas fa-microscope",
        "description": "Configure the cellconsensus-annotate step",
        "properties": {
          "clustering": {
            "type": "string",
            "default": "ccc",
            "description": "Clustering strategy passed to cellconsensus-annotate.",
            "fa_icon": "fas fa-object-group",
            "enum": ["ccc", "precomputed"]
          },
          "cluster_key": {
            "type": "string",
            "description": "Column in adata.obs with cluster labels (required for precomputed clustering).",
            "fa_icon": "fas fa-key"
          },
          "levels": {
            "type": "string",
            "default": "1,2,3",
            "description": "Comma-separated hierarchy levels to emit, from {1,2,3}.",
            "fa_icon": "fas fa-layer-group",
            "pattern": "^[1-3](,[1-3])*$"
          },
          "output_format": {
            "type": "string",
            "default": "name",
            "description": "Label representation for predictions.",
            "fa_icon": "fas fa-tag",
            "enum": ["name", "cl_id", "key"]
          },
          "n_neighbors": {
            "type": "integer",
            "default": 20,
            "description": "Level-1 nearest neighbors (ccc mode).",
            "fa_icon": "fas fa-project-diagram",
            "minimum": 1
          },
          "n_neighbors_lvl2": {
            "type": "integer",
            "default": 10,
            "description": "Level-2 nearest neighbors (ccc mode).",
            "fa_icon": "fas fa-project-diagram",
            "minimum": 1
          },
          "n_neighbors_lvl3": {
            "type": "integer",
            "default": 5,
            "description": "Level-3 nearest neighbors (ccc mode).",
            "fa_icon": "fas fa-project-diagram",
            "minimum": 1
          },
          "n_smooth": {
            "type": "integer",
            "default": 1,
            "description": "Smoothing iterations (ccc mode).",
            "fa_icon": "fas fa-broom",
            "minimum": 0
          },
          "ref_top_k": {
            "type": "integer",
            "default": 200,
            "description": "Top consensus markers per cell type.",
            "fa_icon": "fas fa-list-ol",
            "minimum": 1
          },
          "graph_level": {
            "type": "integer",
            "default": 3,
            "description": "Consensus level for the ccc kNN graph.",
            "fa_icon": "fas fa-sitemap",
            "enum": [1, 2, 3]
          },
          "include_cancer": {
            "type": "boolean",
            "default": false,
            "description": "Add cancer key(s) as level-1 classes during fit.",
            "fa_icon": "fas fa-disease"
          },
          "cancer_types": {
            "type": "string",
            "description": "Comma-separated cancer keys for --include-cancer (default: pan-cancer 'cancer').",
            "fa_icon": "fas fa-disease"
          },
          "save_model": {
            "type": "boolean",
            "default": false,
            "description": "Persist the fitted CellConsensus model to model.pkl.",
            "fa_icon": "fas fa-save"
          }
        }
      },
      "visualize_options": {
        "title": "Visualize options",
        "type": "object",
        "fa_icon": "fas fa-chart-bar",
        "description": "Options for the cellconsensus-visualize plotting step",
        "properties": {
          "skip_visualize": {
            "type": "boolean",
            "default": false,
            "description": "Skip the cellconsensus-visualize plotting step.",
            "fa_icon": "fas fa-forward"
          },
          "visualize_spatial_key": {
            "type": "string",
            "default": "spatial",
            "description": "Key in adata.obsm with 2-D coordinates for the spatial plot.",
            "fa_icon": "fas fa-map-marked-alt"
          },
          "visualize_point_size": {
            "type": "number",
            "default": 6,
            "description": "Marker size for the spatial scatter plot.",
            "fa_icon": "fas fa-braille",
            "minimum": 0
          }
        }
      },
      "input_output_options": {
        "title": "Input/output options",
        "type": "object",
        "fa_icon": "fas fa-terminal",
        "description": "Define where the pipeline should find input data and save output data.",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address for completion summary.",
            "fa_icon": "fas fa-envelope",
            "pattern": "^([a-zA-Z0-9_\\-\\.]+)@([a-zA-Z0-9_\\-\\.]+)\\.([a-zA-Z]{2,5})$"
          },
          "multiqc_title": {
            "type": "string",
            "description": "MultiQC report title.",
            "fa_icon": "fas fa-file-signature"
          }
        }
      },
      "generic_options": {
        "title": "Generic options",
        "type": "object",
        "fa_icon": "fas fa-cogs",
        "description": "Less common options for the pipeline.",
        "properties": {
          "publish_dir_mode": {
            "type": "string",
            "default": "copy",
            "description": "Method used to save pipeline results.",
            "fa_icon": "fas fa-copy",
            "enum": ["symlink", "rellink", "link", "copy", "copyNoFollow", "move"],
            "hidden": true
          },
          "validate_params": {
            "type": "boolean",
            "default": true,
            "description": "Validate parameters against schema at runtime",
            "fa_icon": "fas fa-check-square",
            "hidden": true
          }
        }
      }
    }
  },
  "ui": {}
}
